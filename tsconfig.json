{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "our-lib": [
        "./packages/our-lib/src/index.ts"
      ],
      "@/books/*": [
        "./src/app/books/*"
      ],
      "@/book-pages/*": [
        "./src/app/book-pages/*"
      ],
      "@/reviews/*": [
        "./src/app/reviews/*"
      ],
      "@/sales/*": [
        "./src/app/sales/*"
      ],
      "@/drop-box-locations/*": [
        "./src/app/drop-box-locations/*"
      ],
      "@/snacks/*": [
        "./src/app/snacks/*"
      ],
      "@/testing/*": [
        "./src/testing/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
