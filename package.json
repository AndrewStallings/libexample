{
  "name": "library-example",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:lib && next build",
    "build:lib": "npm run build --workspace our-lib",
    "lint": "npm run lint:app && npm run lint:lib",
    "lint:app": "eslint src next.config.ts vitest.config.ts vitest.setup.ts",
    "lint:app:fix": "eslint src next.config.ts vitest.config.ts vitest.setup.ts --fix",
    "lint:lib": "npm run lint --workspace our-lib",
    "lint:lib:fix": "npm run lint --workspace our-lib -- --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.0.0",
    "@tanstack/react-query": "^5.99.0",
    "drizzle-orm": "^1.0.0-beta.21",
    "mssql": "^11.0.1",
    "next": "^16.0.0",
    "our-lib": "file:./packages/our-lib",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.0"
  }
}
